      "charStart": 2050,
      "factId": "hz.web.9b6d8319fce8c5fe.fact.3",
      "kind": "bullet",
      "text": "I believe I understand the problems it tries to solve, and I fully acknowledge that those are problems worth solving.",
      "tokens": [
        "believe",
        "understand",
        "problems",
        "tries",
        "solve",
        "fully",
        "acknowledge",
        "those",
