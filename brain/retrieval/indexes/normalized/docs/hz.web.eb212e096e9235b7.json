    {
      "charEnd": 1123,
      "charStart": 1034,
      "factId": "hz.web.eb212e096e9235b7.fact.3",
      "kind": "bullet",
      "text": "Every service that spins up an OAuth-enabled API ends up being its own isolated system.",
      "tokens": [
        "every",
        "service",
        "spins",
        "up",
        "oauth",
        "enabled",
