      "factId": "hz.web.6a53e3b2f5b03b87.fact.1",
      "kind": "bullet",
      "text": "Omni Auth Skip to content OmniAuth is a Ruby authentication framework that provides a standardized interface to many different authentication providers such as Facebook, OpenID, and even traditional username and password.",
      "tokens": [
        "omni",
        "auth",
        "skip",
