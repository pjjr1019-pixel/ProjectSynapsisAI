  "rules": [
    {
      "ruleId": "hz.web.44116608b5710af8.rule.1",
      "text": "Easy QUnit should be easy-to-use from start to finish.",
      "tokens": [
        "easy",
        "qunit",
        "easy",
        "use",
        "start",
        "finish"
      ]
    },
    {
      "ruleId": "hz.web.44116608b5710af8.rule.2",
      "text": "Setting up your first test with should be super simple, requiring as little overhead as possible.",
      "tokens": [
        "setting",
        "up",
        "your",
        "first",
        "test",
        "super",
        "simple",
