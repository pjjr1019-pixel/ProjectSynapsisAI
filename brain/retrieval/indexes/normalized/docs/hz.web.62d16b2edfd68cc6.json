      "charStart": 2002,
      "factId": "hz.web.62d16b2edfd68cc6.fact.3",
      "kind": "bullet",
      "text": "I believe I understand the problems it tries to solve, and I fully acknowledge that those are problems worth solving.",
      "tokens": [
        "believe",
        "understand",
        "problems",
        "tries",
        "solve",
        "fully",
        "acknowledge",
        "those",
