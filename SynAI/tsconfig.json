{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "vite/client"
    ],
    "paths": {
      "@contracts": [
        "./packages/contracts/src/index.ts"
      ],
      "@contracts/*": [
        "./packages/contracts/src/*"
      ],
      "@memory/*": [
        "./packages/memory/src/*"
      ],
      "@local-ai/*": [
        "./packages/local-ai/src/*"
      ],
      "@web-search": [
        "./packages/web-search/src/index.ts"
      ],
      "@web-search/*": [
        "./packages/web-search/src/*"
      ],
      "@desktop/*": [
        "./apps/desktop/src/*"
      ]
    }
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "tests/**/*.ts",
    "vite.config.ts",
    "electron.vite.config.ts",
    "tailwind.config.ts"
  ]
}
