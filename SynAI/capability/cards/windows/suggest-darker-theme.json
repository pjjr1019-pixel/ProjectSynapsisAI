  ],
  "risk_level": "low",
  "approval_required": false,
  "retry_policy": {
    "maxAttempts": 1,
    "retryDelayMs": 0
  },
  "tags": [
    "windows",
    "ui",
    "theme"
  ],
  "enabled": true,
  "priority": 80,
  "platform": "windows",
  "environment_preconditions": [],
  "regression_group": "windows-core",
  "prerequisite_tests": [],
  "timeout_ms": 45000,
  "expected_artifacts": [
    "model-response.structured.json"
  ]
}
