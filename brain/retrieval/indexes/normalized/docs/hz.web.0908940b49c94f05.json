    },
    {
      "charEnd": 1177,
      "charStart": 822,
      "factId": "hz.web.0908940b49c94f05.fact.3",
      "kind": "bullet",
      "text": "The NCBI was established in 1988 by an act of the United States Congress as division of the National Library of Medicine at the National Institutes of Health, with a mission to find new approaches to deal with the increasing volume and complexity of biological data in order to facilitate the understanding of genes and their role in health and disease.",
