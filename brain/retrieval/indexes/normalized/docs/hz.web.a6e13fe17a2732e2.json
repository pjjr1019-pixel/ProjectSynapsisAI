: 25px; height: 25px; text-indent: -9999px; } #cboxPrevious:hover { background-position: -75px -25px; } #cboxNext { position: absolute; bottom: 0; left: 27px; background: url(images/controls.png) no-repeat -50px 0; width: 25px; height: 25px; text-indent: -9999px; } #cboxNext:hover { background-position: -50px -25px; } #cboxClose { position: absolute; bottom: 0; right: 0; background: url(images/controls.png) no-repeat -25px 0; width: 25px; height: 25px; text-indent: -9999px; } #cboxClose { top: 14px; right: 14px; padding-left: 23px; background: none; } #colorbox #cboxClose:before { position: absolute; font-family: \"Font Awesome 5 Free\"; top: 0; left: 0px; content: \"\\f00d\"; color: #808080; font-weight: bold; text-indent: 0; font-size: 1.4rem; } #cboxClose:hover { background-position: -25px -25px; } #cboxOverlay { background-image: none; background-color: #000; opacity: 0.7 !important; } /* The following fixes a problem where IE7 and IE8 replace a PNG's alpha transparency with a black fill when an alpha filter (opacity change) is set on the element or ancestor element.",
