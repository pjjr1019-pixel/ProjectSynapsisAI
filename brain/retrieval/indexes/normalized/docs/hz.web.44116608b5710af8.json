        "issue"
      ]
    },
    {
      "ruleId": "hz.web.44116608b5710af8.rule.4",
      "text": "And it should do so without interrupting or corrupting other tests.",
      "tokens": [
        "so",
        "without",
        "interrupting",
        "corrupting",
        "other",
        "tests"
      ]
    },
    {
      "ruleId": "hz.web.44116608b5710af8.rule.5",
      "text": "Additionally, QUnit should be fast to make it easy for developers to have confidence that putting their tests on their critical path won’t slow them down.",
      "tokens": [
        "additionally",
        "qunit",
        "fast",
        "make",
        "easy",
