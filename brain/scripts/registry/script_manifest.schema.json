{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "horizons://brain/scripts/registry/script_manifest.schema.json",
  "title": "Horizons Script Manifest",
  "type": "object",
  "required": [
    "id",
    "title",
    "description",
    "category",
    "inputs",
    "outputs",
    "side_effects",
    "permissions_needed",
    "safe_to_autorun",
    "requires_confirmation",
    "timeout_seconds",
    "platform",
    "path",
    "version",
    "created_by",
    "last_verified"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "aliases": { "type": "array", "items": { "type": "string" } },
    "tags": { "type": "array", "items": { "type": "string" } },
    "category": { "type": "string", "minLength": 1 },
    "inputs": { "type": "object" },
    "outputs": { "type": "object" },
    "side_effects": { "type": "array", "items": { "type": "string" } },
    "permissions_needed": { "type": "array", "items": { "type": "string" } },
    "safe_to_autorun": { "type": "boolean" },
    "requires_confirmation": { "type": "boolean" },
    "timeout_seconds": { "type": "number", "minimum": 1 },
    "platform": { "type": "array", "items": { "type": "string" } },
    "path": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "created_by": { "type": "string", "minLength": 1 },
    "last_verified": { "type": "string", "minLength": 1 },
    "argument_schema": { "type": "object" },
    "usage_examples": { "type": "array", "items": { "type": "string" } },
    "safety_notes": { "type": "array", "items": { "type": "string" } },
    "input_output_description": { "type": "string" },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "modifies_state": { "type": "boolean" },
    "read_only": { "type": "boolean" },
    "reversible": { "type": "boolean" },
    "creation_source": { "type": "string" },
    "last_updated_time": { "type": "string" },
    "policy_class": { "type": "string" }
  },
  "additionalProperties": true
}
