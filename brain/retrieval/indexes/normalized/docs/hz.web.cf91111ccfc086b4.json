      "charEnd": 519,
      "charStart": 387,
      "factId": "hz.web.cf91111ccfc086b4.fact.2",
      "kind": "bullet",
      "text": "Nearly every company with an API used by third party developers has implemented OAuth to enable people to build apps on top of it.",
