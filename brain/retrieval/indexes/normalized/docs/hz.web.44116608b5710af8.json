        "down"
      ]
    },
    {
      "ruleId": "hz.web.44116608b5710af8.rule.6",
      "text": "Universal QUnit should be universally applicable for testing JavaScript code and support many different environments.",
      "tokens": [
        "universal",
        "qunit",
        "universally",
        "applicable",
        "testing",
        "javascript",
