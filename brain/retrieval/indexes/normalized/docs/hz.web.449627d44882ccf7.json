    },
    {
      "charEnd": 863,
      "charStart": 651,
      "factId": "hz.web.449627d44882ccf7.fact.3",
      "kind": "bullet",
      "text": "This talk considers how although the Luhn algorithm is a mathematical function, surprisingly its effect can be expressed using a grammar, and that therefore credit card numbers actually have an internal syntax.",
      "tokens": [
        "talk",
        "considers",
        "although",
