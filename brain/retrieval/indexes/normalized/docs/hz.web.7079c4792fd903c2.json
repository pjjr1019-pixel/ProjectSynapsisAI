      "ruleId": "hz.web.7079c4792fd903c2.rule.1",
      "text": "Since LinkedIn is the owner of the Brand, please do not file any applications with any intellectual property office for any marks which incorporate the Brand.",
      "tokens": [
        "since",
        "linkedin",
