      "charStart": 345,
      "factId": "hz.web.71210b454e35b25d.fact.3",
      "kind": "bullet",
      "text": "The GMPG attempts to stimulate simplification of virtual substructures and bring people to question established structures and their relationships.",
      "tokens": [
        "gmpg",
